# ============================================================
# EvoNet-Core Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- AI Provider API Keys ---
NVIDIA_API_KEY=your_nvidia_api_key_here
GROQ_API_KEY=your_groq_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_KEY=your_cloudflare_api_key

# --- Vector Database ---
PINECONE_API_KEY=your_pinecone_api_key

# --- Graph Database ---
NEO4J_AUTH=neo4j/your_password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Local AI (Ollama) ---
LOCAL_AI_ENABLED=false
LOCAL_AI_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_AI_MODEL=qwen2.5-coder:14b

# --- GitHub Integration ---
GITHUB_TOKEN=your_github_token
GITHUB_REPO=your_username/your_repo

# --- Optional: Threat Intelligence Sources ---
OTX_API_KEY=your_alienvault_otx_key
VT_API_KEY=your_virustotal_key

# --- API Security ---
API_SECRET_KEY=your_secret_key_for_api_auth

# --- Federated Learning ---
FL_CLIENT_ID=default_client
